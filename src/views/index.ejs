<%- include('./includes/head'); %>
<%- include('./includes/nav'); %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8">
      <div class="agenda-card">

        <!-- Cabeçalho -->
        <div class="agenda-header">
          <div class="agenda-icone">
            <svg viewBox="0 0 24 24">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h1 class="agenda-titulo">Agenda</h1>
        </div>
        <p class="agenda-subtitulo">Seus contatos estão listados abaixo</p>

        <%- include('./includes/messages'); %>

        <div class="agenda-divisor"></div>

        <!-- Tabela -->
      <div class="tabela-scroll-wrapper">

  <% if (contatos.length > 0) { %>
  <!-- Thead fixo fora do scroll -->
  <table class="agenda-table" style="margin-bottom:0">
    <thead>
      <tr>
        <th>Contato</th>
        <th>Telefone</th>
        <th>E-mail</th>
        <th style="text-align:center">Ações</th>
      </tr>
    </thead>
  </table>
  <% } %>

  <!-- Tbody com scroll -->
  <div class="tabela-scroll-body" id="tabelaScrollBody">
    <table class="agenda-table">
      <tbody>
        <% if (contatos.length === 0) { %>
          <tr>
            <td colspan="4">
              <div class="agenda-vazio">
                <svg viewBox="0 0 24 24">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <p>Nenhum contato encontrado.</p>
              </div>
            </td>
          </tr>
        <% } else { %>
          <% contatos.forEach(contato => { %>
            <tr>
              <td>
                <div class="contato-nome">
                  <div class="contato-avatar">
                    <%= contato.nome.charAt(0).toUpperCase() %><%= contato.sobrenome ? contato.sobrenome.charAt(0).toUpperCase() : '' %>
                  </div>
                  <div style="font-weight:500"><%= contato.nome %> <%= contato.sobrenome %></div>
                </div>
              </td>
              <td>
                <div class="info-celula">
                  <svg viewBox="0 0 24 24">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.63 3.37 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.13 1 .38 1.98.74 2.91a2 2 0 0 1-.45 2.11L7.91 8.72a16 16 0 0 0 6.37 6.37l.87-.87a2 2 0 0 1 2.11-.45c.93.36 1.91.61 2.91.74A2 2 0 0 1 22 16.92z"/>
                  </svg>
                  <%= contato.telefone %>
                </div>
              </td>
              <td>
                <div class="info-celula">
                  <svg viewBox="0 0 24 24">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                  <%= contato.email %>
                </div>
              </td>
              <td>
                <div class="acoes-celula">
                  <a href="/contact/index/<%= contato._id %>" class="acao-editar">
                    <svg viewBox="0 0 24 24">
                      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    Editar
                  </a>
                  <a href="/contact/delete/<%= contato._id %>" class="acao-excluir">
                    <svg viewBox="0 0 24 24">
                      <polyline points="3 6 5 6 21 6"/>
                      <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                      <path d="M10 11v6"/>
                      <path d="M14 11v6"/>
                      <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                    </svg>
                    Excluir
                  </a>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Fade inferior (some quando chega no fim) -->
  <div class="tabela-scroll-fade" id="tabelaFade"></div>

</div>




        <!-- Rodapé contador -->
        <% if (contatos.length > 0) { %>
        <div class="agenda-rodape">
          <span class="agenda-contador">
            <span><%= contatos.length %></span> contato<%= contatos.length !== 1 ? 's' : '' %> encontrado<%= contatos.length !== 1 ? 's' : '' %>
          </span>
        </div>
        <% } %>

      </div>
    </div>

    <div class="col-lg-2"></div>
  </div>
</div>

<%- include('./includes/footer'); %>
